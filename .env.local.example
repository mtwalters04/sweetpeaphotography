# Copy this file to .env.local and fill in values.
# .env.local is gitignored. Never commit real secrets.
# This file is committed — only put placeholders here.

# --- Supabase (dev project) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloudflare R2 (Phase 4+) ---
# Leave commented or use "placeholder" values until ready — hasR2() stays false and upload routes no-op / skip.
# R2_ACCOUNT_ID=placeholder
# R2_ACCESS_KEY_ID=placeholder
# R2_SECRET_ACCESS_KEY=placeholder
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=
# Optional duplicate for Vercel builds: if set, next/image can allow this host (public site covers).
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL=
# R2_BUCKET=sweetpea-dev

# --- Stripe (Phase 3) ---
# SK can be "placeholder" until real keys — booking with a card stays off, but full studio-credit deposits still work once DB migration is applied.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (added when transactional email lands) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Sweet Pea Photography <hello@mail.sweetpeaphotography.com>
